WP_BASE_URL=https://your-wordpress-site.example
WP_USERNAME=your-wordpress-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Add this later when you are ready to point the same MCP at production.
WP_LIVE_BASE_URL=

# Keep false unless you intentionally point WP_BASE_URL at production and want write tools enabled.
WP_ALLOW_PRODUCTION_WRITES=false
